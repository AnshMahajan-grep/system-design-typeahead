# Copy to .env to run the backend OUTSIDE docker (local dev).
# Inside docker these are injected by docker-compose instead.
PORT=8080
DATABASE_URL=postgres://typeahead:typeahead@localhost:5432/typeahead
REDIS_NODES=localhost:6390,localhost:6391,localhost:6392
CACHE_TTL_SECONDS=60
BATCH_FLUSH_MS=2000
BATCH_MAX_SIZE=200
SUGGEST_LIMIT=10
RECENCY_WEIGHT=1.0
POPULARITY_WEIGHT=1.0
TRENDING_DECAY=0.95
TRENDING_DECAY_MS=60000
